# Backend Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_DB=restaurant_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Database URL (used by SQLAlchemy/Alembic)
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/restaurant_db

# JWT Authentication
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=Restaurant Management System
